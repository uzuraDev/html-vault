# ─────────────────────────────────────────────────────────────
# HTML Vault 設定サンプル
#   このファイルを `.env` にコピーして使います:  cp .env.example .env
#   docker compose は .env を自動で読み込みます。
# ─────────────────────────────────────────────────────────────

# 公開ポート。Docker では「ホスト側の公開ポート」を指す（コンテナ内は 3000 固定）。
#   例: PORT=8080 にすると http://localhost:8080 で開ける。
# 素の Node で直接起動する場合はアプリの待受ポートになる。既定 3000。
PORT=3000

# 待受アドレス。
#   - Docker で動かす場合は 0.0.0.0（コンテナ外へ公開するため）。Dockerfile が既定で設定済み。
#   - 素の Node でローカルのみに絞りたい場合は 127.0.0.1。
HOST=0.0.0.0

# セッション署名鍵。**本番では必ず固定値を設定してください**。
#   未設定だと起動毎にランダム生成され、再起動でログアウトされます。
#   生成例:  openssl rand -hex 32
SESSION_SECRET=

# HTTPS の背後（リバースプロキシ/トンネルで TLS 終端）で動かすなら 1。
#   Secure Cookie を有効化します。直接 HTTP で使う検証時は 0 のまま。
BEHIND_HTTPS=0

# データ保存先ディレクトリ。auth.json / index.json / snippets/ が作られます。
#   Docker では /data（VOLUME）を既定にしています。素の Node なら ./data。
DATA_DIR=/data

# アップロード/保存できる HTML の最大サイズ（MB）。既定 10。
MAX_UPLOAD_MB=10

# 表示言語（en / ja）。既定 en。
#   アプリの文言（UI＋サーバメッセージ）をこの1言語で固定します（ランタイム切替なし）。
#   Docker ではビルド時に焼き込むため、変更したら `docker compose up -d --build` で再ビルドが必要です。
#   素の Node では `npm start`（= build:i18n を実行）で反映されます。
APP_LANG=en

# 初期ログインパスワード。
#   - 設定すると、初回起動時に auth.json が無ければこの値でログインユーザーを作成します。
#   - 未設定なら自動生成もログ表示もしません（パスワードはログに残しません）。
#     その場合 auth.json が無い間はログイン不可。`node setpass.js`（npm run setpass）で
#     設定するか、この値を設定して再起動してください。
#   - 一度 auth.json が出来た後は無視されます。変更は `npm run setpass` で行ってください。
#   ※平文の秘密情報です。設定する場合も .env はコミットしないでください（.gitignore 済み）。
AUTH_PASSWORD=

# API トークン（任意）。ヘッドレスなアップロード用。
#   設定すると、HTTP ヘッダ `Authorization: Bearer <この値>` で
#   スニペットの作成（POST /api/snippets）と一覧（GET /api/snippets）を許可します。
#   MCP サーバ等から「Claude が生成した HTML を直接 Vault に保存する」用途を想定。
#   ブラウザの Cookie 認証とは別系統で、CSRF の対象外（ヘッダ認証のため）。
#   未設定ならトークン認証は無効（従来どおりログイン必須）。
#   生成例:  openssl rand -hex 32   ／ 秘密情報なので .env はコミットしないこと。
API_TOKEN=
